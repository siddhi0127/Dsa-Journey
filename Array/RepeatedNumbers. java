package basic;

public class RepeatedNumber
{
public static void main(String args[])
{
	int arr[]= {6,1,3,1,2,1,1,3};

	int maxcount=0;
	int res=0;
	
	for(int i=0;i<arr.length;i++) {
		int count=0;
		for(int j=0;j<arr.length;j++) {
			
			if(arr[i]==arr[j]) {
				count++;
			}	
			
		}

		if(count>maxcount ) {
			maxcount=count;
			res=arr[i];
		}
	}
	System.out.println("Repeated element : "+res);
	System.out.println("Count : "+maxcount);
}
}
